# ===========================================
# Environment Variables for Hide NB Studio
# ===========================================
# Copy this file to .env.local and fill in the values

# -------------------------------------------
# Required: Gemini API
# -------------------------------------------
GEMINI_API_KEY=your_gemini_api_key_here

# -------------------------------------------
# Required: Authentication
# -------------------------------------------
AUTH_SECRET=your_auth_secret_here
NEXTAUTH_SECRET=your_auth_secret_here

# -------------------------------------------
# Optional: Google OAuth (for Google Sign-in)
# -------------------------------------------
AUTH_GOOGLE_ID=your_google_client_id_here
AUTH_GOOGLE_SECRET=your_google_client_secret_here

# -------------------------------------------
# Optional: Allowed Emails
# -------------------------------------------
# Comma-separated list of allowed email addresses
# Leave empty to allow all authenticated users
ALLOWED_EMAILS=user1@example.com,user2@example.com

# -------------------------------------------
# Optional: Gemini Model Configuration
# -------------------------------------------
GEMINI_IMAGE_MODEL=gemini-3.1-flash-image-preview

# -------------------------------------------
# Environment
# -------------------------------------------
NODE_ENV=development